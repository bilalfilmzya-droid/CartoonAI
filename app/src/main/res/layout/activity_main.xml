<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/header_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp"
            android:paddingTop="40dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/icon_bg"
                android:gravity="center"
                android:text="🎨"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CartoonAI"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Image ko cartoon banao ✨"
                    android:textColor="@color/purple_light"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Upload Screen -->
        <LinearLayout
            android:id="@+id/layoutUpload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖼️"
                android:textSize="64sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apni photo upload karo"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Koi bhi image — selfie, nature, ya kuch bhi!"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="36dp"/>

            <Button
                android:id="@+id/btnPickImage"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/btn_primary"
                android:text="📂  Gallery se Photo Chunein"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Filter Pills -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💥 Comic" android:background="@drawable/pill_bg"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:padding="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✨ Anime" android:background="@drawable/pill_bg"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:padding="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✏️ Sketch" android:background="@drawable/pill_bg"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:padding="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎨 Watercolor" android:background="@drawable/pill_bg"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:padding="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🌈 Neon" android:background="@drawable/pill_bg"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:padding="8dp" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📺 Retro" android:background="@drawable/pill_bg"
                    android:textColor="@color/text_muted" android:textSize="12sp"
                    android:padding="8dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Editor Screen -->
        <LinearLayout
            android:id="@+id/layoutEditor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Image Preview Card -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/imagePreview"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:scaleType="centerInside"
                    android:padding="4dp"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/purple_main"/>
            </FrameLayout>

            <!-- Filter Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎭  FILTER CHUNEIN"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- Filter Grid Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button android:id="@+id/btnComic"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@color/filter_inactive"
                    android:text="💥\nComic" android:textColor="@color/white"
                    android:textSize="11sp" android:textStyle="bold"/>

                <Button android:id="@+id/btnAnime"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@color/filter_inactive"
                    android:text="✨\nAnime" android:textColor="@color/white"
                    android:textSize="11sp" android:textStyle="bold"/>

                <Button android:id="@+id/btnSketch"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@color/filter_inactive"
                    android:text="✏️\nSketch" android:textColor="@color/white"
                    android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Filter Grid Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button android:id="@+id/btnWatercolor"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@color/filter_inactive"
                    android:text="🎨\nWatercolor" android:textColor="@color/white"
                    android:textSize="11sp" android:textStyle="bold"/>

                <Button android:id="@+id/btnNeon"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    android:background="@color/filter_inactive"
                    android:text="🌈\nNeon" android:textColor="@color/white"
                    android:textSize="11sp" android:textStyle="bold"/>

                <Button android:id="@+id/btnRetro"
                    android:layout_width="0dp" android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@color/filter_inactive"
                    android:text="📺\nRetro" android:textColor="@color/white"
                    android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button android:id="@+id/btnSave"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="2" android:layout_marginEnd="10dp"
                    android:background="@drawable/btn_primary"
                    android:text="⬇️  Gallery mein Save" android:textColor="@color/white"
                    android:textStyle="bold" android:visibility="gone"/>

                <Button android:id="@+id/btnShare"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/btn_outline"
                    android:text="📤 Share" android:textColor="@color/purple_main"
                    android:textStyle="bold" android:visibility="gone"/>
            </LinearLayout>

            <Button android:id="@+id/btnNewPhoto"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:background="@drawable/btn_ghost"
                android:text="🔄  Nai Photo Choose Karo"
                android:textColor="@color/text_muted"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
